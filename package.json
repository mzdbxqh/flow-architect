{
  "name": "@flow-architect/plugin",
  "version": "0.1.1",
  "type": "module",
  "engines": { "node": ">=22" },
  "scripts": {
    "build": "node scripts/build-adapters.mjs",
    "build:check": "node scripts/build-adapters.mjs --check",
    "check:skills": "node scripts/check-skills.mjs",
    "test": "node --test test/*.test.mjs",
    "test:contract": "node scripts/check-skills.mjs && node scripts/build-adapters.mjs --check",
    "test:smoke": "node --test test/integrated-review.test.mjs"
  },
  "dependencies": {
    "ajv": ">=8.11.0",
    "fast-xml-parser": "^4",
    "yaml": "^2",
    "exceljs": "^4",
    "mammoth": "^1",
    "pdfjs-dist": "^4"
  },
  "files": [
    "skills/",
    "references/",
    "scripts/",
    "agents/",
    "adapters/",
    "docs/",
    ".agents/",
    ".claude-plugin/",
    ".codex-plugin/",
    "INSTALL.md",
    "README.md",
    "README.zh-CN.md",
    "LICENSE",
    "NOTICE",
    "package.json"
  ],
  "license": "Apache-2.0"
}
