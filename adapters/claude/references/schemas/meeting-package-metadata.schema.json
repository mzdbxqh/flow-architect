{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "package_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_-]+$"
    },
    "process_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "string",
      "pattern": "^r[0-9]{2,}$"
    },
    "based_on_revision": {
      "type": ["string", "null"],
      "pattern": "^r[0-9]{2,}$"
    },
    "runtime_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "content_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  },
  "required": [
    "schema_version",
    "package_id",
    "process_id",
    "title",
    "revision",
    "based_on_revision",
    "runtime_version",
    "content_hash"
  ],
  "additionalProperties": false
}
