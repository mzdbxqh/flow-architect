{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "meeting-package-payload",
  "title": "Meeting Package Payload V2",
  "description": "完整 V2 会议包 payload，含流程卡片、活动一览、图表、BPMN、问题、字段证据和来源摘要",
  "type": "object",
  "required": [
    "metadata",
    "process_card",
    "activities",
    "diagram",
    "bpmn_xml",
    "questions",
    "provenance",
    "source_summary"
  ],
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "type": "object",
      "required": [
        "schema_version",
        "package_id",
        "process_id",
        "title",
        "revision",
        "based_on_revision",
        "runtime_version",
        "content_hash"
      ],
      "additionalProperties": false,
      "properties": {
        "schema_version": { "type": "string", "const": "2.0.0" },
        "package_id": { "type": "string", "pattern": "^[A-Za-z0-9_-]+$" },
        "process_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "revision": { "type": "string", "pattern": "^r[0-9]{2,}$" },
        "based_on_revision": { "type": ["string", "null"], "pattern": "^r[0-9]{2,}$" },
        "runtime_version": { "type": "string", "const": "2.0.0" },
        "content_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
      }
    },
    "process_card": {
      "type": "object",
      "required": [
        "process_id", "name", "level", "is_leaf", "description",
        "purpose", "owner", "parent_process_name", "inputs", "outputs",
        "start", "end_results", "performance_indicators"
      ],
      "additionalProperties": false,
      "properties": {
        "process_id": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_-]*$" },
        "name": { "type": "string", "minLength": 1 },
        "level": { "type": "string", "enum": ["L1", "L2", "L3", "L4", "L5"] },
        "is_leaf": { "type": "boolean" },
        "description": { "type": "string" },
        "purpose": { "type": ["string", "null"] },
        "owner": { "type": ["string", "null"], "minLength": 1 },
        "parent_process_name": { "type": ["string", "null"] },
        "inputs": { "type": "array", "items": { "type": "string" } },
        "outputs": { "type": "array", "items": { "type": "string" } },
        "start": {
          "type": "object",
          "required": ["event_id", "name", "event_type"],
          "additionalProperties": false,
          "properties": {
            "event_id": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_-]*$" },
            "name": { "type": "string", "minLength": 1 },
            "event_type": { "type": "string", "enum": ["NONE", "MESSAGE", "TIMER", "SIGNAL", "CONDITIONAL"] }
          }
        },
        "end_results": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["event_id", "name"],
            "additionalProperties": false,
            "properties": {
              "event_id": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_-]*$" },
              "name": { "type": "string", "minLength": 1 }
            }
          }
        },
        "performance_indicators": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["indicator_id", "name"],
            "additionalProperties": false,
            "properties": {
              "indicator_id": { "type": "string" },
              "name": { "type": "string", "minLength": 1 },
              "target": { "type": "string" },
              "unit": { "type": "string" }
            }
          }
        }
      }
    },
    "activities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "activity_id", "name", "description", "activity_type",
          "responsibility_model", "role_assignments", "tools",
          "inputs", "process_summary", "outputs",
          "completion_criteria", "references",
          "main_task_id", "completeness"
        ],
        "additionalProperties": false,
        "properties": {
          "activity_id": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_-]*$" },
          "name": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "activity_type": { "type": "string", "enum": ["STANDARD", "REVIEW_MEETING", "DECISION_ACTIVITY"] },
          "responsibility_model": { "type": "string", "enum": ["RASCI", "OARP"] },
          "role_assignments": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["role_id", "responsibility"],
              "additionalProperties": false,
              "properties": {
                "role_id": { "type": "string", "minLength": 1 },
                "responsibility": { "type": "string", "enum": ["R", "A", "S", "C", "I", "O", "P"] }
              }
            }
          },
          "sla": {
            "type": ["object", "null"],
            "properties": {
              "value": { "type": "number", "minimum": 0 },
              "unit": { "type": "string", "enum": ["MINUTE", "HOUR", "WORKING_DAY", "CALENDAR_DAY", "WEEK", "MONTH"] },
              "start_condition": { "type": "string" },
              "end_condition": { "type": "string" },
              "raw_text": { "type": "string" }
            },
            "additionalProperties": false
          },
          "tools": { "type": "array", "items": { "type": "string" } },
          "inputs": { "type": "array", "items": { "type": "string" } },
          "process_summary": { "type": "string" },
          "outputs": { "type": "array", "items": { "type": "string" } },
          "completion_criteria": { "type": "array", "items": { "type": "string" } },
          "references": { "type": "array", "items": { "type": "string" } },
          "main_task_id": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_-]*$" },
          "confirmation": {
            "type": ["object", "null"],
            "properties": {
              "confirmation_task_id": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_-]*$" },
              "confirm_role_id": { "type": "string", "minLength": 1 },
              "co_completes": { "type": "boolean" },
              "confirm_bears_final_responsibility": { "type": "boolean" },
              "no_formal_approval_meeting": { "type": "boolean" }
            },
            "required": ["confirmation_task_id", "confirm_role_id", "co_completes", "confirm_bears_final_responsibility", "no_formal_approval_meeting"],
            "additionalProperties": false
          },
          "completeness": { "type": "string", "enum": ["COMPLETE", "NEEDS_CONFIRMATION", "CONFLICTED"] },
          "evidence_refs": { "type": "array", "items": { "type": "string", "pattern": "^B-[a-zA-Z0-9_-]+$" } }
        }
      }
    },
    "diagram": {
      "type": "object",
      "required": ["lanes", "nodes", "flows", "task_bindings", "layout_version"],
      "additionalProperties": false,
      "properties": {
        "lanes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["lane_id", "name", "role_id"],
            "additionalProperties": false,
            "properties": {
              "lane_id": { "type": "string" },
              "name": { "type": "string" },
              "role_id": { "type": "string" }
            }
          }
        },
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["node_id", "node_type", "name", "lane_id"],
            "additionalProperties": false,
            "properties": {
              "node_id": { "type": "string" },
              "node_type": {
                "type": "string",
                "enum": [
                  "MAIN_TASK", "CONFIRMATION_TASK",
                  "GATEWAY_XOR", "GATEWAY_AND", "GATEWAY_OR",
                  "START_EVENT", "END_EVENT",
                  "INTERMEDIATE_MESSAGE_CATCH", "INTERMEDIATE_MESSAGE_THROW",
                  "INTERMEDIATE_TIMER_CATCH",
                  "INTERMEDIATE_LINK_CATCH", "INTERMEDIATE_LINK_THROW"
                ]
              },
              "name": { "type": "string" },
              "lane_id": { "type": ["string", "null"] },
              "activity_id": { "type": ["string", "null"] },
              "event_definition": { "type": ["object", "null"] }
            }
          }
        },
        "flows": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["flow_id", "source_ref", "target_ref"],
            "additionalProperties": false,
            "properties": {
              "flow_id": { "type": "string" },
              "source_ref": { "type": "string" },
              "target_ref": { "type": "string" },
              "condition": { "type": ["object", "null"] }
            }
          }
        },
        "task_bindings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["activity_id", "main_task_id"],
            "additionalProperties": false,
            "properties": {
              "activity_id": { "type": "string" },
              "main_task_id": { "type": "string" },
              "confirmation_task_id": { "type": ["string", "null"] }
            }
          }
        },
        "layout_version": { "type": "string", "const": "2.0.0" }
      }
    },
    "bpmn_xml": {
      "type": "string",
      "minLength": 1
    },
    "questions": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "required": ["question_id", "text", "target_paths", "status", "answer"],
        "additionalProperties": false,
        "properties": {
          "question_id": { "type": "string", "pattern": "^Q-[a-zA-Z0-9_-]+$" },
          "text": { "type": "string", "minLength": 1 },
          "target_paths": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "status": { "type": "string", "enum": ["OPEN", "CONFIRMED", "NOT_APPLICABLE"] },
          "answer": { "type": "string" }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^/": {
          "type": "object",
          "required": ["certainty", "evidence_refs"],
          "additionalProperties": false,
          "properties": {
            "certainty": { "type": "string", "enum": ["EXPLICIT", "INFERRED", "MISSING", "CONFLICT", "NOT_APPLICABLE"] },
            "evidence_refs": { "type": "array", "items": { "type": "string", "pattern": "^B-[a-zA-Z0-9_-]+$" } }
          }
        }
      }
    },
    "source_summary": {
      "type": "object",
      "required": ["total_blocks", "formats", "evidence_refs"],
      "additionalProperties": false,
      "properties": {
        "total_blocks": { "type": "integer", "minimum": 0 },
        "formats": { "type": "array", "items": { "type": "string" } },
        "evidence_refs": { "type": "array", "items": { "type": "string", "pattern": "^B-[a-zA-Z0-9_-]+$" } }
      }
    }
  }
}
