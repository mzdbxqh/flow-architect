{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "process-draft",
  "title": "Process Draft V2",
  "description": "L5 流程草稿 V2，包含流程卡片、活动一览表、业务图模型、问题、字段证据和来源摘要",
  "type": "object",
  "required": ["schema_version", "process_card", "activities", "diagram", "questions", "provenance", "source_summary"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "2.0.0",
      "description": "Schema 版本号，固定为 2.0.0"
    },
    "process_card": {
      "$ref": "process-card",
      "description": "流程卡片"
    },
    "activities": {
      "$ref": "activity-catalog",
      "description": "L5 活动一览表"
    },
    "diagram": {
      "$ref": "diagram-draft",
      "description": "V2 业务图模型"
    },
    "questions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["question_id", "text", "target_paths", "status"],
        "additionalProperties": false,
        "properties": {
          "question_id": { "type": "string", "pattern": "^Q-[a-zA-Z0-9_-]+$" },
          "text": { "type": "string", "minLength": 1 },
          "target_paths": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1,
            "description": "指向 process-draft 中的 JSON Pointer 路径"
          },
          "status": {
            "type": "string",
            "enum": ["OPEN", "CONFIRMED", "NOT_APPLICABLE"]
          },
          "answer": { "type": "string" },
          "evidence_refs": {
            "type": "array",
            "items": { "type": "string", "pattern": "^B-[a-zA-Z0-9_-]+$" }
          }
        }
      },
      "description": "待确认问题数组"
    },
    "provenance": {
      "$ref": "field-provenance",
      "description": "字段级证据"
    },
    "source_summary": {
      "type": "object",
      "required": ["total_blocks", "formats", "evidence_refs"],
      "additionalProperties": false,
      "properties": {
        "total_blocks": { "type": "integer", "minimum": 0 },
        "formats": {
          "type": "array",
          "items": { "type": "string" }
        },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string", "pattern": "^B-[a-zA-Z0-9_-]+$" }
        }
      },
      "description": "来源摘要"
    }
  }
}
