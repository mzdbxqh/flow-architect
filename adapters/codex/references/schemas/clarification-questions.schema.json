{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^[A-Za-z0-9_-]+$"
      },
      "text": {
        "type": "string",
        "minLength": 1
      },
      "element_ids": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "status": {
        "type": "string",
        "enum": ["OPEN", "CONFIRMED", "NOT_APPLICABLE"]
      },
      "answer": {
        "type": "string"
      }
    },
    "required": ["id", "text", "element_ids", "status", "answer"],
    "additionalProperties": false
  }
}
