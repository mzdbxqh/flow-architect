{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "array",
  "minItems": 0,
  "items": {
    "type": "object",
    "properties": {
      "question_id": {
        "type": "string",
        "pattern": "^Q-[a-zA-Z0-9_-]+$"
      },
      "text": {
        "type": "string",
        "minLength": 1
      },
      "target_paths": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "status": {
        "type": "string",
        "enum": ["OPEN", "CONFIRMED", "NOT_APPLICABLE"]
      },
      "answer": {
        "type": "string"
      }
    },
    "required": ["question_id", "text", "target_paths", "status", "answer"],
    "additionalProperties": false
  }
}
