{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://flow-architect/schemas/diagram-model.schema.json",
  "title": "Diagram Model",
  "description": "Structured representation of a diagram extracted from visual or semi-structured sources.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "elements", "flows", "metadata"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "elements": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["element_id", "type", "name", "parent_id", "lane_id", "sub_type"],
        "properties": {
          "element_id": { "type": "string" },
          "type": {
            "type": "string",
            "enum": [
              "POOL",
              "LANE",
              "TASK",
              "SUB_PROCESS",
              "EVENT",
              "GATEWAY",
              "DATA_OBJECT",
              "UNKNOWN_VISUAL_ELEMENT"
            ]
          },
          "name": { "type": "string" },
          "parent_id": { "type": ["string", "null"] },
          "lane_id": { "type": ["string", "null"] },
          "sub_type": { "type": ["string", "null"] },
          "geometry": { "type": ["object", "null"] }
        }
      }
    },
    "flows": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["flow_id", "type", "source_ref", "target_ref", "is_default"],
        "properties": {
          "flow_id": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["SEQUENCE_FLOW", "MESSAGE_FLOW", "ASSOCIATION"]
          },
          "source_ref": { "type": "string" },
          "target_ref": { "type": "string" },
          "is_default": { "type": "boolean" },
          "geometry": { "type": ["object", "null"] }
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["parse_mode", "source_format", "confidence", "warnings"],
      "properties": {
        "parse_mode": { "type": "string" },
        "source_format": { "type": "string" },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
