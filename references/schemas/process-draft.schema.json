{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "process-draft",
  "title": "Process Draft",
  "description": "L5 流程草稿，包含泳道、元素、流转和问题",
  "type": "object",
  "required": ["title", "level", "process_id", "boundary", "lanes", "elements", "flows", "questions", "conflicts", "source_summary"],
  "additionalProperties": false,
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "流程标题"
    },
    "level": {
      "type": "string",
      "const": "L5",
      "description": "流程层级，固定为 L5"
    },
    "process_id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "流程唯一标识"
    },
    "boundary": {
      "type": "object",
      "required": ["start", "end"],
      "additionalProperties": false,
      "properties": {
        "start": { "type": "string", "minLength": 1 },
        "end": { "type": "string", "minLength": 1 }
      },
      "description": "流程边界"
    },
    "lanes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["lane_id", "name", "org_candidates"],
        "additionalProperties": false,
        "properties": {
          "lane_id": { "type": "string", "pattern": "^Lane-[a-zA-Z0-9_-]+$" },
          "name": { "type": "string", "minLength": 1 },
          "org_candidates": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "description": "泳道数组"
    },
    "elements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["element_id", "kind", "name", "lane_id", "inputs", "outputs", "evidence_refs", "certainty", "question_ids"],
        "additionalProperties": false,
        "properties": {
          "element_id": { "type": "string", "pattern": "^(Activity|Event|Gateway)-[a-zA-Z0-9_-]+$" },
          "kind": {
            "type": "string",
            "enum": ["ACTIVITY", "EVENT", "DECISION"]
          },
          "name": { "type": "string", "minLength": 1 },
          "lane_id": {
            "type": ["string", "null"],
            "pattern": "^Lane-[a-zA-Z0-9_-]+$"
          },
          "inputs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "outputs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "evidence_refs": {
            "type": "array",
            "items": { "type": "string", "pattern": "^B-[a-zA-Z0-9_-]+$" }
          },
          "certainty": {
            "type": "string",
            "enum": ["EXPLICIT", "INFERRED", "CONFLICT", "MISSING", "NOT_APPLICABLE"]
          },
          "question_ids": {
            "type": "array",
            "items": { "type": "string", "pattern": "^Q-[a-zA-Z0-9_-]+$" }
          }
        }
      },
      "description": "流程元素数组"
    },
    "flows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["flow_id", "source_ref", "target_ref", "condition", "evidence_refs"],
        "additionalProperties": false,
        "properties": {
          "flow_id": { "type": "string", "pattern": "^Flow-[a-zA-Z0-9_-]+$" },
          "source_ref": { "type": "string" },
          "target_ref": { "type": "string" },
          "condition": { "type": ["string", "null"] },
          "evidence_refs": {
            "type": "array",
            "items": { "type": "string", "pattern": "^B-[a-zA-Z0-9_-]+$" }
          }
        }
      },
      "description": "流转关系数组"
    },
    "questions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["question_id", "text", "element_ids", "status", "evidence_refs"],
        "additionalProperties": false,
        "properties": {
          "question_id": { "type": "string", "pattern": "^Q-[a-zA-Z0-9_-]+$" },
          "text": { "type": "string", "minLength": 1 },
          "element_ids": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "status": {
            "type": "string",
            "enum": ["OPEN", "CONFIRMED", "NOT_APPLICABLE"]
          },
          "answer": { "type": "string" },
          "evidence_refs": {
            "type": "array",
            "items": { "type": "string", "pattern": "^B-[a-zA-Z0-9_-]+$" }
          }
        }
      },
      "description": "待确认问题数组"
    },
    "conflicts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["conflict_id", "description", "fact_ids", "evidence_refs"],
        "additionalProperties": false,
        "properties": {
          "conflict_id": { "type": "string", "pattern": "^C-[a-zA-Z0-9_-]+$" },
          "description": { "type": "string", "minLength": 1 },
          "fact_ids": {
            "type": "array",
            "items": { "type": "string", "pattern": "^F-[a-zA-Z0-9_-]+$" }
          },
          "evidence_refs": {
            "type": "array",
            "items": { "type": "string", "pattern": "^B-[a-zA-Z0-9_-]+$" }
          }
        }
      },
      "description": "冲突数组"
    },
    "source_summary": {
      "type": "object",
      "required": ["total_blocks", "formats", "evidence_refs"],
      "additionalProperties": false,
      "properties": {
        "total_blocks": { "type": "integer", "minimum": 0 },
        "formats": {
          "type": "array",
          "items": { "type": "string" }
        },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string", "pattern": "^B-[a-zA-Z0-9_-]+$" }
        }
      },
      "description": "来源摘要"
    }
  }
}
