{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://flow-architect/schemas/input-manifest.schema.json",
  "title": "Input Manifest",
  "description": "Inventory of artifacts provided as input to a run.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "artifacts", "warnings"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "run_id": { "type": "string" },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "file_path",
          "sha256",
          "size_bytes",
          "kind",
          "format",
          "parse_mode",
          "confidence",
          "capabilities",
          "degradation_reason"
        ],
        "properties": {
          "file_path": { "type": "string" },
          "sha256": { "type": "string" },
          "size_bytes": { "type": "number" },
          "kind": {
            "type": "string",
            "enum": ["ARCHITECTURE", "DIAGRAM", "MIXED", "UNKNOWN"]
          },
          "format": { "type": "string" },
          "parse_mode": {
            "type": "string",
            "enum": ["STRUCTURED", "SEMI_STRUCTURED", "VISUAL_ONLY", "UNSUPPORTED"]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "capabilities": {
            "type": "array",
            "items": { "type": "string" }
          },
          "degradation_reason": {
            "type": ["string", "null"]
          }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
