{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://flow-architect/schemas/finding-set.schema.json",
  "title": "Finding Set",
  "description": "Collection of findings produced by a review stage.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "findings"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "finding_id",
          "rule_id",
          "category",
          "severity",
          "verdict",
          "artifact_refs",
          "target_refs",
          "evidence",
          "expected",
          "actual",
          "recommendation",
          "confidence",
          "business_confirmation_required",
          "source_rule_refs",
          "fingerprint"
        ],
        "properties": {
          "finding_id": { "type": "string" },
          "rule_id": { "type": "string" },
          "category": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["BLOCKER", "CRITICAL", "MAJOR", "MINOR", "INFO"]
          },
          "verdict": {
            "type": "string",
            "enum": ["PASS", "FAIL", "INSUFFICIENT_EVIDENCE"]
          },
          "artifact_refs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "target_refs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "artifact_id",
                "locator_type",
                "locator",
                "excerpt",
                "observation"
              ],
              "properties": {
                "artifact_id": { "type": "string" },
                "locator_type": {
                  "type": "string",
                  "enum": [
                    "LINE",
                    "PAGE",
                    "BPMN_ELEMENT",
                    "MERMAID_NODE",
                    "IMAGE_REGION"
                  ]
                },
                "locator": { "type": "string" },
                "excerpt": { "type": "string" },
                "observation": { "type": "string" }
              }
            }
          },
          "expected": { "type": "string" },
          "actual": { "type": "string" },
          "recommendation": { "type": "string" },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "business_confirmation_required": { "type": "boolean" },
          "source_rule_refs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "fingerprint": { "type": "string" }
        }
      }
    }
  }
}
