<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  id="Definitions_1"
  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Pool_Order" name="Order Process" processRef="Process_Order" />
    <bpmn:participant id="Pool_Warehouse" name="Warehouse" processRef="Process_Warehouse" />
    <bpmn:messageFlow id="MsgFlow_1" sourceRef="Task_Ship" targetRef="Task_Receive" name="Ship Notification" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Order" isExecutable="true">
    <bpmn:laneSet id="LaneSet_Order">
      <bpmn:lane id="Lane_Sales" name="Sales">
        <bpmn:flowNodeRef>Start_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ReceiveOrder</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_Check</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Fulfillment" name="Fulfillment">
        <bpmn:flowNodeRef>Task_ProcessOrder</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Ship</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_1</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="Start_1" name="Order Received">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="Task_ReceiveOrder" name="Receive Order">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_Check" name="Order Valid?" default="Flow_4">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="Task_ProcessOrder" name="Process Order">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="End_1" name="Order Complete">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:incoming>Flow_4</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:task id="Task_Ship" name="Ship Order">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="Start_1" targetRef="Task_ReceiveOrder" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_ReceiveOrder" targetRef="GW_Check" />
    <bpmn:sequenceFlow id="Flow_3" name="Valid" sourceRef="GW_Check" targetRef="Task_ProcessOrder" />
    <bpmn:sequenceFlow id="Flow_4" name="Invalid" sourceRef="GW_Check" targetRef="End_1" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_ProcessOrder" targetRef="Task_Ship" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Task_Ship" targetRef="End_1" />
  </bpmn:process>

  <bpmn:process id="Process_Warehouse" isExecutable="false">
    <bpmn:startEvent id="Start_2" name="Receive Notification">
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:task id="Task_Receive" name="Receive Shipment">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="End_2" name="Done">
      <bpmn:incoming>Flow_8</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_7" sourceRef="Start_2" targetRef="Task_Receive" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Task_Receive" targetRef="End_2" />
  </bpmn:process>

</bpmn:definitions>
