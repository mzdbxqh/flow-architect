{
  "description": "采购申请流程三类语义任务的固定 Oracle，用于验证模型输出的关键语义事实。不比较自然语言措辞，只比较结构化投影。subject_key 为模型生成的稳定业务键，oracle 按 kind 和语义属性验证。",
  "batch_id": "EB-procurement-demo",
  "batch_sha256": "c9eb4c5318d11343244d1fb869cd2f6d23a6267199a325223577051433739261",
  "forbidden_fields": [
    "x", "y", "width", "height", "bounds", "position", "coordinates",
    "waypoints", "bpmn_xml", "bpmn_di", "xml", "html", "svg", "layout", "di"
  ],
  "PROCESS_CARD": {
    "required_kinds": ["PROCESS_NAME", "START_EVENT", "END_EVENT"],
    "expected_kinds": ["PROCESS_NAME", "PROCESS_LEVEL", "PROCESS_PURPOSE", "PROCESS_OWNER", "START_EVENT", "END_EVENT"],
    "optional_kinds": ["INPUT", "OUTPUT", "KPI", "BOUNDARY"],
    "must_have_end_events": true,
    "min_facts": 4,
    "process_key_must_match": true,
    "all_facts_must_have_evidence_refs": true,
    "end_event_labels_must_mention": ["批准", "驳回", "退回", "结束"],
    "expected_start_event_count": 1,
    "expected_end_event_count": 2,
    "end_event_semantics": ["采购已批准", "退回申请人"]
  },
  "ACTIVITY_CATALOG": {
    "_comment": "expected_activity_count=4 仅用于 align 后 canonical 活动。raw capture 允许额外结果别名（如 A-reject-return），alignment 层会将 IPO 全空的结果别名合入 END_EVENT。",
    "required_kinds": ["ACTIVITY"],
    "expected_kinds": ["ACTIVITY", "ROLE"],
    "optional_kinds": ["RESPONSIBILITY", "INPUT", "OUTPUT", "PROCESS", "SLA", "TOOL", "COMPLETION_CRITERIA", "REFERENCE", "CONFIRMATION_CONDITION"],
    "min_activity_facts": 4,
    "min_facts": 4,
    "process_key_must_match": true,
    "all_facts_must_have_evidence_refs": true,
    "activity_labels_must_mention": ["提交", "初审", "复核", "审批"],
    "expected_l5_activity_names": ["提交采购申请", "经理初审", "采购复核", "审批决策"],
    "expected_activity_count": 4
  },
  "CONTROL_FLOW": {
    "required_kinds": ["START_EVENT", "END_EVENT", "FLOW"],
    "expected_kinds": ["START_EVENT", "END_EVENT", "FLOW", "GATEWAY_XOR"],
    "optional_kinds": ["GATEWAY_AND", "GATEWAY_OR", "CONDITION", "LANE", "EXCEPTION", "RULE"],
    "must_have_start_and_end": true,
    "min_facts": 3,
    "min_flow_facts": 7,
    "process_key_must_match": true,
    "all_facts_must_have_evidence_refs": true,
    "flow_attributes_must_have_source_target": true,
    "expected_start_event_count": 1,
    "expected_end_event_count": 2,
    "expected_gateway_xor_count": 3,
    "expected_flow_count": 7,
    "expected_lanes": ["申请泳道", "审核泳道"],
    "min_lane_count": 2
  }
}
