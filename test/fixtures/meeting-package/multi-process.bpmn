<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
             id="Definitions_2"
             targetNamespace="http://bpmn.io/schema/bpmn">

  <process id="Process_A" isExecutable="true">
    <startEvent id="Start_A">
      <outgoing>Flow_A</outgoing>
    </startEvent>
    <task id="Task_A1" name="A1">
      <incoming>Flow_A</incoming>
    </task>
    <sequenceFlow id="Flow_A" sourceRef="Start_A" targetRef="Task_A1" />
  </process>

  <process id="Process_B" isExecutable="true">
    <startEvent id="Start_B">
      <outgoing>Flow_B</outgoing>
    </startEvent>
    <task id="Task_B1" name="B1">
      <incoming>Flow_B</incoming>
    </task>
    <sequenceFlow id="Flow_B" sourceRef="Start_B" targetRef="Task_B1" />
  </process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_2">
    <bpmndi:BPMNPlane id="BPMNPlane_2" bpmnElement="Process_A">
      <bpmndi:BPMNShape id="Start_A_di" bpmnElement="Start_A">
        <dc:Bounds x="100" y="100" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_A1_di" bpmnElement="Task_A1">
        <dc:Bounds x="200" y="78" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_A_di" bpmnElement="Flow_A">
        <di:waypoint x="136" y="118" />
        <di:waypoint x="200" y="118" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
    <bpmndi:BPMNPlane id="BPMNPlane_3" bpmnElement="Process_B">
      <bpmndi:BPMNShape id="Start_B_di" bpmnElement="Start_B">
        <dc:Bounds x="100" y="300" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_B1_di" bpmnElement="Task_B1">
        <dc:Bounds x="200" y="278" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_B_di" bpmnElement="Flow_B">
        <di:waypoint x="136" y="318" />
        <di:waypoint x="200" y="318" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>
