<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
             id="Definitions_1"
             targetNamespace="http://bpmn.io/schema/bpmn">

  <collaboration id="Collaboration_1">
    <participant id="Participant_1" name="采购审批流程" processRef="Process_1" />
  </collaboration>

  <process id="Process_1" isExecutable="true">
    <laneSet id="LaneSet_1">
      <lane id="Lane_Applicant" name="申请人">
        <flowNodeRef>StartEvent_1</flowNodeRef>
        <flowNodeRef>Task_Review</flowNodeRef>
      </lane>
      <lane id="Lane_Manager" name="经理">
        <flowNodeRef>Task_Approve</flowNodeRef>
        <flowNodeRef>Task_Rework</flowNodeRef>
        <flowNodeRef>EndEvent_1</flowNodeRef>
      </lane>
    </laneSet>

    <startEvent id="StartEvent_1" name="开始">
      <outgoing>Flow_Start_Review</outgoing>
    </startEvent>

    <task id="Task_Review" name="审核采购申请">
      <incoming>Flow_Start_Review</incoming>
      <outgoing>Flow_Review_Approve</outgoing>
    </task>

    <task id="Task_Approve" name="批准采购">
      <incoming>Flow_Review_Approve</incoming>
      <outgoing>Flow_Approve_End</outgoing>
    </task>

    <task id="Task_Rework" name="退回修改">
      <incoming>Flow_Review_Rework</incoming>
      <outgoing>Flow_Rework_Review</outgoing>
    </task>

    <endEvent id="EndEvent_1" name="结束">
      <incoming>Flow_Approve_End</incoming>
    </endEvent>

    <sequenceFlow id="Flow_Start_Review" sourceRef="StartEvent_1" targetRef="Task_Review" />
    <sequenceFlow id="Flow_Review_Approve" sourceRef="Task_Review" targetRef="Task_Approve" />
    <sequenceFlow id="Flow_Review_Rework" sourceRef="Task_Review" targetRef="Task_Rework" />
    <sequenceFlow id="Flow_Rework_Review" sourceRef="Task_Rework" targetRef="Task_Review" />
    <sequenceFlow id="Flow_Approve_End" sourceRef="Task_Approve" targetRef="EndEvent_1" />
  </process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="Participant_1_di" bpmnElement="Participant_1" isHorizontal="true">
        <dc:Bounds x="160" y="60" width="900" height="400" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Applicant_di" bpmnElement="Lane_Applicant" isHorizontal="true">
        <dc:Bounds x="190" y="60" width="870" height="200" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Manager_di" bpmnElement="Lane_Manager" isHorizontal="true">
        <dc:Bounds x="190" y="260" width="870" height="200" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="232" y="152" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Review_di" bpmnElement="Task_Review">
        <dc:Bounds x="350" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Approve_di" bpmnElement="Task_Approve">
        <dc:Bounds x="350" y="330" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Rework_di" bpmnElement="Task_Rework">
        <dc:Bounds x="550" y="330" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="572" y="352" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_Start_Review_di" bpmnElement="Flow_Start_Review">
        <di:waypoint x="268" y="170" />
        <di:waypoint x="350" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Review_Approve_di" bpmnElement="Flow_Review_Approve">
        <di:waypoint x="400" y="210" />
        <di:waypoint x="400" y="330" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Review_Rework_di" bpmnElement="Flow_Review_Rework">
        <di:waypoint x="450" y="170" />
        <di:waypoint x="600" y="170" />
        <di:waypoint x="600" y="330" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Rework_Review_di" bpmnElement="Flow_Rework_Review">
        <di:waypoint x="550" y="370" />
        <di:waypoint x="450" y="370" />
        <di:waypoint x="450" y="210" />
        <di:waypoint x="400" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Approve_End_di" bpmnElement="Flow_Approve_End">
        <di:waypoint x="450" y="370" />
        <di:waypoint x="572" y="370" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>
